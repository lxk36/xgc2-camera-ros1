{
  "apiVersion": "xgc.execution.process/v1",
  "definitions": [
    {
      "id": "xgc2-camera-v4l2-ros1",
      "version": "1.0.0",
      "label": "XGC2 ROS1 camera",
      "description": "Run one fixed or general-purpose V4L2 camera and wait for a real Image message.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "nodeName": {"type": "string", "default": "driver"},
          "cameraNamespace": {"type": "string", "default": "/usb_cam"},
          "imageTopic": {"type": "string", "default": "/usb_cam/image_raw"},
          "backend": {"type": "string", "default": "v4l2", "enum": ["v4l2", "synthetic"]},
          "videoDevice": {"type": "string", "default": "/dev/video0"},
          "width": {"type": "integer", "default": 1920, "minimum": 1, "maximum": 16384},
          "height": {"type": "integer", "default": 1080, "minimum": 1, "maximum": 16384},
          "framerate": {"type": "number", "default": 30.0, "minimum": 0.1, "maximum": 1000.0},
          "pixelFormat": {"type": "string", "default": "mjpeg", "enum": ["mjpeg", "h264", "yuyv", "uyvy", "rgb24", "bgr24", "nv12", "grey"]},
          "captureMode": {"type": "string", "default": "auto", "enum": ["auto", "single-plane", "multi-plane"]},
          "bufferCount": {"type": "integer", "default": 4, "minimum": 2, "maximum": 32},
          "captureTimeoutMs": {"type": "integer", "default": 2000, "minimum": 1, "maximum": 60000},
          "syntheticSeed": {"type": "integer", "default": 1, "minimum": 0, "maximum": 2147483647},
          "outputEncoding": {"type": "string", "default": "bgr8", "enum": ["bgr8", "rgb8", "mono8"]},
          "cameraName": {"type": "string", "default": "usb_cam"},
          "frameId": {"type": "string", "default": "usb_cam_optical_frame"},
          "cameraInfoUrl": {"type": "string", "default": ""},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosIp": {"type": "string", "default": ""},
          "rosHostname": {"type": "string", "default": ""},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_driver/xgc_camera_driver_node",
        "args": [
          "__name:=${nodeName}",
          "__ns:=${cameraNamespace}",
          "_backend:=${backend}",
          "_video_device:=${videoDevice}",
          "_width:=${width}",
          "_height:=${height}",
          "_framerate:=${framerate}",
          "_pixel_format:=${pixelFormat}",
          "_capture_mode:=${captureMode}",
          "_buffer_count:=${bufferCount}",
          "_capture_timeout_ms:=${captureTimeoutMs}",
          "_synthetic_seed:=${syntheticSeed}",
          "_output_encoding:=${outputEncoding}",
          "_camera_name:=${cameraName}",
          "_frame_id:=${frameId}",
          "_camera_info_url:=${cameraInfoUrl}"
        ],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_IP": "${rosIp}",
          "ROS_HOSTNAME": "${rosHostname}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "LD_LIBRARY_PATH": "/opt/ros/noetic/lib:/opt/ros/noetic/lib/x86_64-linux-gnu:/opt/ros/noetic/lib/aarch64-linux-gnu",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        }
      },
      "readiness": {
        "kind": "exec",
        "command": {
          "executable": "/opt/ros/noetic/bin/rostopic",
          "args": ["echo", "-n", "1", "${imageTopic}/header/stamp"],
          "env": {"ROS_MASTER_URI": "${rosMasterUri}"}
        },
        "interval": 2000000000,
        "timeout": 12000000000,
        "successThreshold": 1,
        "failureThreshold": 5
      },
      "liveness": {
        "kind": "exec",
        "command": {
          "executable": "/opt/ros/noetic/bin/rostopic",
          "args": ["echo", "-n", "1", "${imageTopic}/header/stamp"],
          "env": {"ROS_MASTER_URI": "${rosMasterUri}"}
        },
        "interval": 5000000000,
        "timeout": 12000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "stop": {"gracePeriod": 8000000000},
      "restart": {"mode": "on-failure", "maxRestarts": 3, "backoff": 1000000000}
    },
    {
      "id": "xgc2-camera-intrinsic-calibrator-ros1",
      "version": "2.0.0",
      "label": "XGC2 camera intrinsic calibration WebUI",
      "description": "Serve a local WebUI with a 3D sample guide and X/Y/Size/Skew coverage: auto-collect diverse chessboard views, solve intrinsics (cv2-direct), and persist camera_matrix + distortion.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "imageTopic": {"type": "string", "default": "/usb_cam/image_raw"},
          "cameraInfoTopic": {"type": "string", "default": "/usb_cam/camera_info"},
          "outputFile": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/intrinsics.yaml"},
          "referencesDir": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/intrinsic_refs"},
          "boardCols": {"type": "integer", "default": 7, "minimum": 2, "maximum": 100},
          "boardRows": {"type": "integer", "default": 5, "minimum": 2, "maximum": 100},
          "squareSize": {"type": "number", "default": 0.2, "minimum": 0.000001},
          "boardX": {"type": "number", "default": 2.0},
          "boardY": {"type": "number", "default": 0.0},
          "boardZ": {"type": "number", "default": 1.5},
          "displayWidth": {"type": "integer", "default": 720, "minimum": 64, "maximum": 16384},
          "intrinsicRate": {"type": "number", "default": 6.0, "minimum": 0.1, "maximum": 120.0},
          "jpegQuality": {"type": "integer", "default": 80, "minimum": 1, "maximum": 100},
          "cameraControl": {"type": "boolean", "default": false},
          "cameraModelName": {"type": "string", "default": "gazebo_static_camera"},
          "cameraControlTimeout": {"type": "number", "default": 8.0, "minimum": 0.0},
          "bindAddress": {"type": "string", "default": "127.0.0.1"},
          "httpPort": {"type": "integer", "default": 8766, "minimum": 1, "maximum": 65535},
          "frameAncestors": {"type": "string", "default": "'self' http://127.0.0.1:* http://localhost:*"},
          "allowedOrigins": {"type": "string", "default": ""},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera-calibration"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_calibration/intrinsic_calibrator_web.py",
        "args": ["__name:=xgc_camera_intrinsic_calibrator_web", "_image_topic:=${imageTopic}", "_camera_info_topic:=${cameraInfoTopic}", "_output_file:=${outputFile}", "_references_dir:=${referencesDir}", "_board_cols:=${boardCols}", "_board_rows:=${boardRows}", "_square_size:=${squareSize}", "_board_x:=${boardX}", "_board_y:=${boardY}", "_board_z:=${boardZ}", "_display_width:=${displayWidth}", "_intrinsic_rate:=${intrinsicRate}", "_jpeg_quality:=${jpegQuality}", "_camera_control:=${cameraControl}", "_camera_model_name:=${cameraModelName}", "_camera_control_timeout:=${cameraControlTimeout}", "_bind_address:=${bindAddress}", "_http_port:=${httpPort}", "_frame_ancestors:=${frameAncestors}", "_allowed_origins:=${allowedOrigins}"],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        }
      },
      "readiness": {"kind": "process"},
      "liveness": {"kind": "process"},
      "stop": {"gracePeriod": 5000000000},
      "restart": {"mode": "never"}
    },
    {
      "id": "xgc2-camera-extrinsic-calibrator-ros1",
      "version": "2.0.0",
      "label": "XGC2 camera extrinsic calibration WebUI",
      "description": "Serve a local WebUI that matches synchronized pose markers to pixels, solves robust PnP, and persists parent_T_camera_optical.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "imageTopic": {"type": "string", "default": "/usb_cam/image_raw"},
          "cameraInfoTopic": {"type": "string", "default": "/usb_cam/camera_info"},
          "posePrefix": {"type": "string", "default": "/vrpn_client_node"},
          "outputFile": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/extrinsics.yaml"},
          "parentFrame": {"type": "string", "default": "map"},
          "opticalFrame": {"type": "string", "default": "usb_cam_optical_frame"},
          "maximumMarkerAge": {"type": "number", "default": 0.1, "minimum": 0.0},
          "maximumErrorPx": {"type": "number", "default": 5.0, "minimum": 0.0},
          "poseHistorySize": {"type": "integer", "default": 240, "minimum": 2, "maximum": 10000},
          "jpegQuality": {"type": "integer", "default": 80, "minimum": 1, "maximum": 100},
          "bindAddress": {"type": "string", "default": "127.0.0.1"},
          "httpPort": {"type": "integer", "default": 8765, "minimum": 1, "maximum": 65535},
          "frameAncestors": {"type": "string", "default": "'self' http://127.0.0.1:* http://localhost:*"},
          "allowedOrigins": {"type": "string", "default": ""},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera-calibration"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_calibration/extrinsic_calibrator_web.py",
        "args": ["__name:=xgc_camera_extrinsic_calibrator_web", "_image_topic:=${imageTopic}", "_camera_info_topic:=${cameraInfoTopic}", "_pose_prefix:=${posePrefix}", "_output_file:=${outputFile}", "_parent_frame:=${parentFrame}", "_child_frame:=${opticalFrame}", "_maximum_marker_age:=${maximumMarkerAge}", "_maximum_inlier_error_px:=${maximumErrorPx}", "_pose_history_size:=${poseHistorySize}", "_jpeg_quality:=${jpegQuality}", "_bind_address:=${bindAddress}", "_http_port:=${httpPort}", "_frame_ancestors:=${frameAncestors}", "_allowed_origins:=${allowedOrigins}"],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        }
      },
      "readiness": {"kind": "process"},
      "liveness": {"kind": "process"},
      "stop": {"gracePeriod": 5000000000},
      "restart": {"mode": "never"}
    },
    {
      "id": "xgc2-camera-extrinsic-tf-ros1",
      "version": "1.0.0",
      "label": "XGC2 camera extrinsic TF",
      "description": "Publish parent to camera_link to camera_optical_frame from a calibrated runtime asset.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "extrinsicFile": {"type": "string", "default": "/var/lib/xgc2/camera/calibrations/usb_cam/extrinsics.yaml"},
          "parentFrame": {"type": "string", "default": "map"},
          "cameraLinkFrame": {"type": "string", "default": "usb_cam_link"},
          "opticalFrame": {"type": "string", "default": "usb_cam_optical_frame"},
          "static": {"type": "boolean", "default": true},
          "publishRate": {"type": "number", "default": 10.0, "minimum": 0.1},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera-tf"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_calibration/extrinsic_tf_publisher.py",
        "args": ["__name:=xgc_camera_extrinsic_tf", "_extrinsic_file:=${extrinsicFile}", "_parent_frame:=${parentFrame}", "_camera_link_frame:=${cameraLinkFrame}", "_optical_frame:=${opticalFrame}", "_static:=${static}", "_publish_rate:=${publishRate}"],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        }
      },
      "readiness": {"kind": "ros1-node", "address": "${rosMasterUri}", "node": "/xgc_camera_extrinsic_tf"},
      "liveness": {"kind": "ros1-node", "address": "${rosMasterUri}", "node": "/xgc_camera_extrinsic_tf"},
      "stop": {"gracePeriod": 5000000000},
      "restart": {"mode": "on-failure", "maxRestarts": 3, "backoff": 1000000000}
    }
  ]
}
