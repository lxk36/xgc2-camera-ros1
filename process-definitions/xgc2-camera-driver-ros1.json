{
  "apiVersion": "xgc.execution.process/v1",
  "definitions": [
    {
      "id": "xgc2-camera-v4l2-ros1",
      "version": "1.0.0",
      "label": "XGC2 ROS1 camera",
      "description": "Run one fixed or general-purpose V4L2 camera and wait for a real Image message.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "nodeName": {"type": "string", "default": "driver"},
          "cameraNamespace": {"type": "string", "default": "/usb_cam"},
          "imageTopic": {"type": "string", "default": "/usb_cam/image_raw"},
          "backend": {"type": "string", "default": "v4l2", "enum": ["v4l2", "synthetic"]},
          "videoDevice": {"type": "string", "default": "/dev/video0"},
          "width": {"type": "integer", "default": 1920, "minimum": 1, "maximum": 16384},
          "height": {"type": "integer", "default": 1080, "minimum": 1, "maximum": 16384},
          "framerate": {"type": "number", "default": 30.0, "minimum": 0.1, "maximum": 1000.0},
          "pixelFormat": {"type": "string", "default": "mjpeg", "enum": ["mjpeg", "h264", "yuyv", "uyvy", "rgb24", "bgr24", "nv12", "grey"]},
          "captureMode": {"type": "string", "default": "auto", "enum": ["auto", "single-plane", "multi-plane"]},
          "bufferCount": {"type": "integer", "default": 4, "minimum": 2, "maximum": 32},
          "captureTimeoutMs": {"type": "integer", "default": 2000, "minimum": 1, "maximum": 60000},
          "syntheticSeed": {"type": "integer", "default": 1, "minimum": 0, "maximum": 2147483647},
          "outputEncoding": {"type": "string", "default": "bgr8", "enum": ["bgr8", "rgb8", "mono8"]},
          "cameraName": {"type": "string", "default": "usb_cam"},
          "frameId": {"type": "string", "default": "usb_cam_optical_frame"},
          "cameraInfoUrl": {"type": "string", "default": ""},
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "rosIp": {"type": "string", "default": ""},
          "rosHostname": {"type": "string", "default": ""},
          "rosLogDir": {"type": "string", "default": "/var/lib/xgc2/ros/log/camera"}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/lib/xgc_camera_driver/xgc_camera_driver_node",
        "args": [
          "__name:=${nodeName}",
          "__ns:=${cameraNamespace}",
          "_backend:=${backend}",
          "_video_device:=${videoDevice}",
          "_width:=${width}",
          "_height:=${height}",
          "_framerate:=${framerate}",
          "_pixel_format:=${pixelFormat}",
          "_capture_mode:=${captureMode}",
          "_buffer_count:=${bufferCount}",
          "_capture_timeout_ms:=${captureTimeoutMs}",
          "_synthetic_seed:=${syntheticSeed}",
          "_output_encoding:=${outputEncoding}",
          "_camera_name:=${cameraName}",
          "_frame_id:=${frameId}",
          "_camera_info_url:=${cameraInfoUrl}"
        ],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "ROS_IP": "${rosIp}",
          "ROS_HOSTNAME": "${rosHostname}",
          "ROS_LOG_DIR": "${rosLogDir}",
          "ROS_DISTRO": "noetic",
          "ROS_VERSION": "1",
          "ROS_PYTHON_VERSION": "3",
          "ROS_ROOT": "/opt/ros/noetic/share/ros",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "LD_LIBRARY_PATH": "/opt/ros/noetic/lib:/opt/ros/noetic/lib/x86_64-linux-gnu:/opt/ros/noetic/lib/aarch64-linux-gnu",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        }
      },
      "readiness": {
        "kind": "exec",
        "command": {
          "executable": "/opt/ros/noetic/bin/rostopic",
          "args": ["echo", "-n", "1", "${imageTopic}/header/stamp"],
          "env": {"ROS_MASTER_URI": "${rosMasterUri}"}
        },
        "interval": 2000000000,
        "timeout": 12000000000,
        "successThreshold": 1,
        "failureThreshold": 5
      },
      "liveness": {
        "kind": "exec",
        "command": {
          "executable": "/opt/ros/noetic/bin/rostopic",
          "args": ["echo", "-n", "1", "${imageTopic}/header/stamp"],
          "env": {"ROS_MASTER_URI": "${rosMasterUri}"}
        },
        "interval": 5000000000,
        "timeout": 12000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "stop": {"gracePeriod": 8000000000},
      "restart": {"mode": "on-failure", "maxRestarts": 3, "backoff": 1000000000}
    }
  ]
}
