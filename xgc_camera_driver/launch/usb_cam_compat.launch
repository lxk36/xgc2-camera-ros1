<launch>
  <!-- Compatibility contract: /usb_cam/image_raw and /usb_cam/camera_info. -->
  <arg name="backend" default="v4l2" />
  <arg name="video_device" default="/dev/video0" />
  <arg name="width" default="1920" />
  <arg name="height" default="1080" />
  <arg name="framerate" default="30.0" />
  <arg name="pixel_format" default="mjpeg" />
  <arg name="capture_mode" default="auto" />
  <arg name="output_encoding" default="bgr8" />
  <arg name="camera_info_url" default="" />
  <arg name="buffer_count" default="4" />
  <arg name="capture_timeout_ms" default="2000" />
  <arg name="synthetic_seed" default="1" />

  <include file="$(find xgc_camera_driver)/launch/camera.launch">
    <arg name="camera_ns" value="usb_cam" />
    <arg name="backend" value="$(arg backend)" />
    <arg name="video_device" value="$(arg video_device)" />
    <arg name="width" value="$(arg width)" />
    <arg name="height" value="$(arg height)" />
    <arg name="framerate" value="$(arg framerate)" />
    <arg name="pixel_format" value="$(arg pixel_format)" />
    <arg name="capture_mode" value="$(arg capture_mode)" />
    <arg name="output_encoding" value="$(arg output_encoding)" />
    <arg name="camera_info_url" value="$(arg camera_info_url)" />
    <arg name="buffer_count" value="$(arg buffer_count)" />
    <arg name="capture_timeout_ms" value="$(arg capture_timeout_ms)" />
    <arg name="synthetic_seed" value="$(arg synthetic_seed)" />
  </include>
</launch>
