<launch>
  <arg name="image_topic" default="/usb_cam/image_raw" />
  <arg name="camera_info_topic" default="/usb_cam/camera_info" />
  <arg name="pose_prefix" default="/vrpn_client_node" />
  <arg name="output_file" default="$(env HOME)/.local/state/xgc2/camera/calibrations/usb_cam/extrinsics.yaml" />
  <arg name="parent_frame" default="map" />
  <arg name="child_frame" default="usb_cam_optical_frame" />
  <arg name="maximum_marker_age" default="0.1" />
  <arg name="ransac_threshold_px" default="3.0" />
  <arg name="maximum_inlier_error_px" default="5.0" />

  <node pkg="xgc_camera_calibration"
        type="extrinsic_calibrator_ui.py"
        name="xgc_camera_extrinsic_calibrator"
        output="screen">
    <param name="image_topic" value="$(arg image_topic)" />
    <param name="camera_info_topic" value="$(arg camera_info_topic)" />
    <param name="pose_prefix" value="$(arg pose_prefix)" />
    <param name="output_file" value="$(arg output_file)" />
    <param name="parent_frame" value="$(arg parent_frame)" />
    <param name="child_frame" value="$(arg child_frame)" />
    <param name="maximum_marker_age" value="$(arg maximum_marker_age)" />
    <param name="ransac_threshold_px" value="$(arg ransac_threshold_px)" />
    <param name="maximum_inlier_error_px" value="$(arg maximum_inlier_error_px)" />
  </node>
</launch>
