<launch>
  <arg name="image_topic" default="/usb_cam/image_raw" />
  <arg name="camera_info_topic" default="/usb_cam/camera_info" />
  <arg name="output_file" default="$(env HOME)/.local/state/xgc2/camera/calibrations/usb_cam/intrinsics.yaml" />
  <arg name="references_dir" default="$(env HOME)/.local/state/xgc2/camera/calibrations/usb_cam/intrinsic_refs" />
  <arg name="board_cols" default="7" />
  <arg name="board_rows" default="5" />
  <arg name="square_size" default="0.20" />
  <arg name="board_x" default="2.0" />
  <arg name="board_y" default="0.0" />
  <arg name="board_z" default="1.5" />
  <arg name="display_width" default="720" />
  <arg name="intrinsic_rate" default="6.0" />
  <arg name="jpeg_quality" default="80" />
  <!-- camera_control:=true lights up the guide's fly-to / auto-run / live pose
       when running against a Gazebo simulation; leave false for a real camera. -->
  <arg name="camera_control" default="false" />
  <arg name="camera_model_name" default="gazebo_static_camera" />
  <arg name="camera_control_timeout" default="8.0" />
  <arg name="bind_address" default="127.0.0.1" />
  <arg name="http_port" default="8766" />
  <arg name="frame_ancestors" default="'self' http://127.0.0.1:* http://localhost:*" />
  <arg name="allowed_origins" default="" />

  <node pkg="xgc_camera_calibration"
        type="intrinsic_calibrator_web.py"
        name="xgc_camera_intrinsic_calibrator_web"
        output="screen">
    <param name="image_topic" value="$(arg image_topic)" />
    <param name="camera_info_topic" value="$(arg camera_info_topic)" />
    <param name="output_file" value="$(arg output_file)" />
    <param name="references_dir" value="$(arg references_dir)" />
    <param name="board_cols" value="$(arg board_cols)" />
    <param name="board_rows" value="$(arg board_rows)" />
    <param name="square_size" value="$(arg square_size)" />
    <param name="board_x" value="$(arg board_x)" />
    <param name="board_y" value="$(arg board_y)" />
    <param name="board_z" value="$(arg board_z)" />
    <param name="display_width" value="$(arg display_width)" />
    <param name="intrinsic_rate" value="$(arg intrinsic_rate)" />
    <param name="jpeg_quality" value="$(arg jpeg_quality)" />
    <param name="camera_control" value="$(arg camera_control)" />
    <param name="camera_model_name" value="$(arg camera_model_name)" />
    <param name="camera_control_timeout" value="$(arg camera_control_timeout)" />
    <param name="bind_address" value="$(arg bind_address)" />
    <param name="http_port" value="$(arg http_port)" />
    <param name="frame_ancestors" value="$(arg frame_ancestors)" />
    <param name="allowed_origins" value="$(arg allowed_origins)" />
  </node>
</launch>
